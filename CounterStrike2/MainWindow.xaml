<Window x:Class="CounterStrike2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="~NULL Client" Height="680" Width="940"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True">

    <Border Background="{StaticResource Bg}" CornerRadius="14"
            BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ════════════════════ SIDEBAR ════════════════════ -->
            <Border Grid.Column="0" Background="{StaticResource Sidebar}" CornerRadius="14,0,0,14">
                <DockPanel>

                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,24,0,20">
                        <Border Width="32" Height="32" CornerRadius="9" Background="{StaticResource AccentGradient}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#A35BFF" Opacity="0.6" />
                            </Border.Effect>
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="~NULL Client" Foreground="{StaticResource Text}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Attach + status pinned to bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,18">
                        <Button x:Name="AttachBtn" Content="Attach to CS2"
                                Click="AttachBtn_Click" Cursor="Hand"
                                Foreground="White" FontSize="12" FontWeight="SemiBold"
                                Padding="0,10" Margin="0,0,0,8" BorderThickness="0" Height="34">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="8">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#A35BFF" Opacity="0.45" />
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#8A3FE6" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bg" Property="Background" Value="#3A2B5C" />
                                            <Setter TargetName="Bg" Property="Effect">
                                                <Setter.Value><DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0" /></Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Background="{StaticResource Card}" CornerRadius="8" Padding="12,9"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#E0564B" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatusText" Text="Not attached"
                                           Foreground="{StaticResource Muted}" FontSize="11"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Nav buttons -->
                    <StackPanel Margin="0,4,0,0">
                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     IsChecked="True" Checked="Nav_Checked" Tag="Visuals">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="Visuals" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="Misc">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE748;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="Misc" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="Skins">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="Skins" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="Debug">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="Debug" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="Settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ════════════════════ CONTENT PANELS ════════════════════ -->

            <!-- ── VISUALS (default) ── -->
            <Border x:Name="PanelVisuals" Grid.Column="1"
                    Background="{StaticResource Bg}" CornerRadius="0,14,14,0">
                <StackPanel Margin="30,36,30,26">
                    <TextBlock Text="Visuals" Foreground="{StaticResource Text}"
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,3" />
                    <TextBlock Text="ESP and world rendering"
                               Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,14" />
                    <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,20" />

                    <!-- Two-column card layout: Player ESP | Box Style + World -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Player ESP -->
                        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Player ESP" Style="{StaticResource SectionTitle}" />

                                <!-- Enable ESP — no swatch (master toggle) -->
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Enable ESP" IsChecked="{Binding EspEnabled}" />

                                <!-- Rows with inline color swatch: [Label] [swatch] [toggle] -->
                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bounding box" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="BoxColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="BoxColor"><Border.Background><SolidColorBrush Color="#FF4444"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspBox}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Health bar" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="HealthColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="HealthColor"><Border.Background><SolidColorBrush Color="#4FE36A"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspHealth}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Name tag" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="NameColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="NameColor"><Border.Background><SolidColorBrush Color="#FFFFFF"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspName}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Distance" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="DistColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="DistanceColor"><Border.Background><SolidColorBrush Color="#AA60FF"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspDistance}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Weapon" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="WeaponColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="WeaponColor"><Border.Background><SolidColorBrush Color="#1E64DC"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspWeapon}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Skeleton" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="SkelColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="SkeletonColor"><Border.Background><SolidColorBrush Color="#FF4444"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspSkeleton}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bomb carrier" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspBombCarrier}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Snap lines" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="SnapColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="SnapColor"><Border.Background><SolidColorBrush Color="#FF4444"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspSnapLines}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="12,4,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Position" Foreground="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              SelectedValue="{Binding SnapLinePos, Mode=TwoWay}"
                                              SelectedValuePath="Content">
                                        <ComboBoxItem Content="Bottom"/>
                                        <ComboBoxItem Content="Top"/>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Grenades" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border x:Name="GrenColorSwatch" Grid.Column="1" Height="18" CornerRadius="4" Cursor="Hand" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" MouseLeftButtonDown="EspColorSwatch_Click" Tag="GrenadeColor"><Border.Background><SolidColorBrush Color="#FFDD00"/></Border.Background></Border>
                                    <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchOnly}" IsChecked="{Binding EspGrenades}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Show teammates — no swatch -->
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Show teammates" IsChecked="{Binding EspTeam}" />
                            </StackPanel>
                        </Border>

                        <!-- RIGHT: Box Style + Colors + World stacked -->
                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="Box Style" Style="{StaticResource SectionTitle}" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Thickness"
                                                   Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BoxThickness, StringFormat={}{0:0.0}}"
                                                   Foreground="{StaticResource Accent}" FontSize="13" />
                                    </Grid>
                                    <Slider Style="{StaticResource ModernSlider}" Minimum="1" Maximum="5"
                                            Value="{Binding BoxThickness}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="World" Style="{StaticResource SectionTitle}" />
                                    <CheckBox Style="{StaticResource ToggleSwitch}" Content="Dropped weapons" IsChecked="{Binding EspLoot}" />
                                    <CheckBox Style="{StaticResource ToggleSwitch}" Content="Bomb timer"      IsChecked="{Binding EspBomb}" />
                                    <CheckBox Style="{StaticResource ToggleSwitch}" Content="Spectator list"  IsChecked="{Binding SpectatorList}" />
                                    <CheckBox Style="{StaticResource ToggleSwitch}" Content="Radar"           IsChecked="{Binding RadarEnabled}" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Radar opacity"
                                                   Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RadarOpacity, StringFormat={}{0:0.0}}"
                                                   Foreground="{StaticResource Accent}" FontSize="13" />
                                    </Grid>
                                    <Slider Style="{StaticResource ModernSlider}" Minimum="0.1" Maximum="1.0"
                                            Value="{Binding RadarOpacity}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── MISC ── -->
            <Border x:Name="PanelMisc" Grid.Column="1" Visibility="Collapsed"
                    Background="{StaticResource Bg}" CornerRadius="0,14,14,0">
                <StackPanel Margin="30,36,30,26">
                    <TextBlock Text="Misc" Foreground="{StaticResource Text}"
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,3" />
                    <TextBlock Text="Sounds and overlay options"
                               Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,14" />
                    <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,20" />

                    <!-- Two-column: Sounds | Overlay -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Sounds -->
                        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Sounds" Style="{StaticResource SectionTitle}" />

                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Kill sound"
                                          IsChecked="{Binding KillSound}" />
                                <TextBlock x:Name="KillDebugLabel" Text=""
                                           Foreground="{StaticResource Muted}" FontSize="10"
                                           FontFamily="Consolas" Margin="0,2,0,0" />
                                <Grid Margin="0,6,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="6,0,0,6"
                                            Padding="10,7" BorderBrush="{StaticResource Border}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="{Binding KillSoundFileName}"
                                                   Foreground="{StaticResource Muted}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse" Click="BrowseKillSound_Click"
                                            Cursor="Hand" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                            Padding="14,7" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="0,6,6,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#8A3FE6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Weapon equip sound"
                                          IsChecked="{Binding WeaponEquipSound}" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="6,0,0,6"
                                            Padding="10,7" BorderBrush="{StaticResource Border}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="{Binding WeaponEquipSoundFileName}"
                                                   Foreground="{StaticResource Muted}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse" Click="BrowseWeaponSound_Click"
                                            Cursor="Hand" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                            Padding="14,7" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="0,6,6,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#8A3FE6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Hit indicator"
                                          IsChecked="{Binding HitIndicator}" />
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Hit sound"
                                          IsChecked="{Binding HitSound}" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="6,0,0,6"
                                            Padding="10,7" BorderBrush="{StaticResource Border}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="{Binding HitSoundFileName}"
                                                   Foreground="{StaticResource Muted}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse" Click="BrowseHitSound_Click"
                                            Cursor="Hand" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                            Padding="14,7" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="0,6,6,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#8A3FE6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- RIGHT: Overlay -->
                        <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Overlay" Style="{StaticResource SectionTitle}" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Click-through overlay"
                                               Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" x:Name="OverlayBtn" Content="Show overlay"
                                            Click="OverlayBtn_Click" Cursor="Hand"
                                            Foreground="White" FontSize="11" Padding="12,6" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="7">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#8A3FE6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Show FPS counter"  IsChecked="{Binding ShowFps}" />
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Watermark"         IsChecked="{Binding Watermark}" />
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Crosshair overlay" IsChecked="{Binding CrosshairOverlay}" />
                                <Button Content="Customize…" Click="CrosshairCustomize_Click" Cursor="Hand"
                                        HorizontalAlignment="Right" Foreground="{StaticResource Accent}" FontSize="11"
                                        Margin="0,4,0,0" Padding="0" BorderThickness="0" Background="Transparent" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── SKINS ── -->
            <Border x:Name="PanelSkins" Grid.Column="1" Visibility="Collapsed"
                    Background="{StaticResource Bg}" CornerRadius="0,14,14,0">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="30,36,30,26">
                <StackPanel>
                    <TextBlock Text="Skins" Foreground="{StaticResource Text}"
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,3" />
                    <TextBlock Text="Local skin changer — offline / -insecure only"
                               Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,14" />
                    <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,20" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Configure -->
                        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Configure" Style="{StaticResource SectionTitle}" />

                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Skin changer"
                                          IsChecked="{Binding SkinChangerEnabled}" />

                                <!-- Active weapon badge -->
                                <Border Background="{StaticResource Panel}" CornerRadius="7"
                                        Padding="12,9" Margin="0,10,0,0"
                                        BorderBrush="{StaticResource Border}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Active weapon" Foreground="{StaticResource Muted}" FontSize="11" />
                                        <TextBlock x:Name="SkinWeaponLabel" Text="—"
                                                   Foreground="{StaticResource Text}" FontSize="13"
                                                   FontWeight="SemiBold" Margin="0,3,0,0" />
                                        <TextBlock x:Name="SkinDebugLabel" Text=""
                                                   Foreground="{StaticResource Muted}" FontSize="10"
                                                   FontFamily="Consolas" Margin="0,4,0,0" />
                                        <TextBlock x:Name="SkinHudDebugLabel" Text=""
                                                   Foreground="{StaticResource Muted}" FontSize="10"
                                                   FontFamily="Consolas" Margin="0,2,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Paint kit -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="68"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Paint kit ID"
                                               Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="Browse" Click="SkinBrowse_Click" Cursor="Hand"
                                            Foreground="{StaticResource Text}" FontSize="11" FontWeight="SemiBold"
                                            Margin="6,0,0,0" Padding="0,5" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource Panel}" CornerRadius="5"
                                                        BorderBrush="{StaticResource Border}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBox x:Name="SkinPaintKitBox" Grid.Column="1" Text="0"
                                             Background="{StaticResource Panel}" Foreground="{StaticResource Text}"
                                             BorderBrush="{StaticResource Border}" BorderThickness="1"
                                             Padding="7,5" FontSize="12" FontFamily="Consolas">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </Grid>

                                <!-- Wear -->
                                <Grid Margin="0,10,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Wear"
                                               Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SkinWearLabel" Grid.Column="1"
                                               Text="0.001" Foreground="{StaticResource Accent}" FontSize="12"/>
                                </Grid>
                                <Slider x:Name="SkinWearSlider" Style="{StaticResource ModernSlider}"
                                        Minimum="0.001" Maximum="1.0" Value="0.001"
                                        SmallChange="0.001" LargeChange="0.1"
                                        ValueChanged="SkinWearSlider_ValueChanged" />
                                <!-- Wear labels -->
                                <Grid Margin="0,1,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FN"  Foreground="{StaticResource Muted}" FontSize="9" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="MW"  Foreground="{StaticResource Muted}" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="FT"  Foreground="{StaticResource Muted}" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="WW"  Foreground="{StaticResource Muted}" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="BS"  Foreground="{StaticResource Muted}" FontSize="9" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- StatTrak -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="StatTrak™"
                                               Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox x:Name="SkinStatTrakBox" Grid.Column="1" Text="0"
                                             Background="{StaticResource Panel}" Foreground="{StaticResource Text}"
                                             BorderBrush="{StaticResource Border}" BorderThickness="1"
                                             Padding="7,5" FontSize="12" FontFamily="Consolas"
                                             IsEnabled="{Binding ElementName=SkinStatTrakCheck, Path=IsChecked}">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <CheckBox x:Name="SkinStatTrakCheck" Grid.Column="3"
                                              Style="{StaticResource ToggleSwitchOnly}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Legacy Model (mask=2 for old UV skins: USP-S, M4A1-S, etc.) -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Legacy Model" Foreground="{StaticResource Text}" FontSize="13"/>
                                        <TextBlock Text="Enable for USP-S, M4A1-S skins that use old UV layout"
                                                   Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="SkinLegacyModelCheck" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchOnly}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Buttons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button Content="Clear" Click="SkinClear_Click" Cursor="Hand"
                                            Foreground="{StaticResource Muted}" FontSize="12" FontWeight="SemiBold"
                                            Padding="18,8" Margin="0,0,8,0" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource Card}" CornerRadius="7"
                                                        BorderBrush="{StaticResource Border}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="BorderBrush" Value="#6B38C9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="Apply" Click="SkinApply_Click" Cursor="Hand"
                                            Foreground="White" FontSize="12" FontWeight="SemiBold"
                                            Padding="22,8" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="7">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#A35BFF" Opacity="0.4"/>
                                                    </Border.Effect>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#8A3FE6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </Border>

                        <!-- RIGHT: Applied skins list -->
                        <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Applied skins" Style="{StaticResource SectionTitle}" />

                                <ItemsControl x:Name="SkinList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Panel}" CornerRadius="6"
                                                    Padding="11,8" Margin="0,0,0,6"
                                                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding WeaponName}"
                                                                   Foreground="{StaticResource Text}"
                                                                   FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Summary}"
                                                                   Foreground="{StaticResource Muted}" FontSize="11"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="✕" Tag="{Binding WeaponId}"
                                                            Click="SkinRemove_Click" Cursor="Hand"
                                                            FontSize="12" Foreground="{StaticResource Muted}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="8,2" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="SkinListEmpty" Text="No skins configured yet."
                                           Foreground="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0"/>

                                <Border Background="#0D0B14" CornerRadius="7" Padding="12,10" Margin="0,16,0,0">
                                    <TextBlock Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                                               Text="Paint kit IDs: look up your skin on csgostash.com or cs.money, hover the skin and note the paint kit number. Works in offline -insecure bot matches only." />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── DEBUG ── -->
            <Border x:Name="PanelDebug" Grid.Column="1" Visibility="Collapsed"
                    Background="{StaticResource Bg}" CornerRadius="0,14,14,0">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="30,36,30,26">
                    <StackPanel>
                        <TextBlock Text="Debug" Foreground="{StaticResource Text}"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,3" />
                        <TextBlock Text="Resolved addresses and sanity checks"
                                   Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,14" />
                        <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,20" />

                        <Border Style="{StaticResource CardPanel}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Sanity Check"
                                               Style="{StaticResource SectionTitle}" Margin="0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="ScanBtn" Content="Scan Processes" Click="ScanBtn_Click"
                                                Cursor="Hand" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                Padding="12,6" Margin="0,0,8,0" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="#271F38" CornerRadius="6"
                                                            BorderBrush="#A35BFF" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#3A2B5C" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="SanityBtn" Content="Run Test" Click="SanityBtn_Click"
                                                Cursor="Hand" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                Padding="12,6" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#8A3FE6" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bg" Property="Background" Value="#3A2B5C" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <Border Background="#0D0B14" CornerRadius="7" Padding="14,10">
                                    <StackPanel x:Name="SanityResults">
                                        <TextBlock Text="Click 'Scan Processes' to diagnose attach issues, or 'Run Test' for a full check."
                                                   Foreground="{StaticResource Muted}"
                                                   FontSize="11" FontFamily="Consolas" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardPanel}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Resolved Addresses" Style="{StaticResource SectionTitle}" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="MODULE"  Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="NAME"    Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="ADDRESS" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,8" />
                                <ItemsControl x:Name="OffsetTable">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#E0564B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                                    <Setter Property="Fill" Value="#4FE36A" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1" Text="{Binding Module}"
                                                           Foreground="{StaticResource Muted}"
                                                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                           FontSize="12" FontFamily="Consolas" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Muted}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="3" Text="{Binding AddressText}"
                                                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Muted}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                                    <Setter Property="Foreground" Value="#A35BFF" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── SETTINGS ── -->
            <Border x:Name="PanelSettings" Grid.Column="1" Visibility="Collapsed"
                    Background="{StaticResource Bg}" CornerRadius="0,14,14,0">
                <StackPanel Margin="30,36,30,26">
                    <TextBlock Text="Settings" Foreground="{StaticResource Text}"
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,3" />
                    <TextBlock Text="Menu and config"
                               Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,14" />
                    <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,20" />

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="Menu" Style="{StaticResource SectionTitle}" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Toggle key" Foreground="{StaticResource Text}"
                                           FontSize="13" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="6"
                                        Padding="14,5" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                    <TextBlock Text="INSERT" Foreground="{StaticResource Text}" FontSize="12" />
                                </Border>
                            </Grid>
                            <CheckBox Style="{StaticResource ToggleSwitch}" Content="Save config on exit" IsChecked="{Binding SaveOnExit}" />
                            <CheckBox Style="{StaticResource ToggleSwitch}" Content="Start minimized"     IsChecked="{Binding StartMinimized}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="Profiles" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Save and load full config snapshots — ESP, skins, radar, everything"
                                       Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ProfileNameBox" Grid.Column="0" Text=""
                                         Background="{StaticResource Panel}" Foreground="{StaticResource Text}"
                                         BorderBrush="{StaticResource Border}" BorderThickness="1"
                                         Padding="8,6" FontSize="12">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Grid.Column="1" Content="Save" Click="ProfileSave_Click" Cursor="Hand"
                                        Foreground="White" FontSize="12" FontWeight="SemiBold"
                                        Margin="8,0,0,0" Padding="0,7" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg" Background="{StaticResource AccentGradient}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#8A3FE6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <Button Content="Import from file…" Click="ProfileImport_Click" Cursor="Hand"
                                    HorizontalAlignment="Stretch" Foreground="{StaticResource Muted}" FontSize="12"
                                    Padding="0,8" Margin="0,0,0,10" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{StaticResource Card}" CornerRadius="6"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <ItemsControl x:Name="ProfileList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Panel}" CornerRadius="6"
                                                Padding="11,7" Margin="0,0,0,6"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}"
                                                           Foreground="{StaticResource Text}" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="Load" Tag="{Binding}"
                                                        Click="ProfileLoad_Click" Cursor="Hand" FontSize="11"
                                                        Foreground="{StaticResource Accent}" Background="Transparent"
                                                        BorderThickness="0" Padding="8,2" Margin="0,0,4,0"/>
                                                <Button Grid.Column="2" Content="Export" Tag="{Binding}"
                                                        Click="ProfileExport_Click" Cursor="Hand" FontSize="11"
                                                        Foreground="{StaticResource Muted}" Background="Transparent"
                                                        BorderThickness="0" Padding="8,2" Margin="0,0,4,0"/>
                                                <Button Grid.Column="3" Content="✕" Tag="{Binding}"
                                                        Click="ProfileDelete_Click" Cursor="Hand" FontSize="12"
                                                        Foreground="{StaticResource Muted}" Background="Transparent"
                                                        BorderThickness="0" Padding="8,2"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="ProfileListEmpty" Text="No saved profiles yet."
                                       Foreground="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="About" Style="{StaticResource SectionTitle}" />
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12"
                                       Text="~NULL Client — built for local -insecure bot matches and reverse-engineering study only." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Title bar / window controls overlay -->
            <Grid Grid.Column="1" VerticalAlignment="Top" Height="30"
                  Background="Transparent" MouseLeftButtonDown="TitleBar_Drag">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource WindowButton}" Content="&#xE921;" Click="Minimize_Click" />
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>

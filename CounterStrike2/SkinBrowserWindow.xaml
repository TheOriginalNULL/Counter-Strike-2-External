<Window x:Class="CounterStrike2.SkinBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browse Skins"
        Width="760" Height="640"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Topmost="True">

    <Border Background="{StaticResource Bg}" CornerRadius="14"
            BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header / drag handle -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnDrag" Cursor="SizeAll" Margin="22,18,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Browse Skins" Foreground="{StaticResource Text}"
                               FontSize="18" FontWeight="Bold" />
                    <TextBlock x:Name="SubtitleText" Text="Sourced from the public CS2 item schema"
                               Foreground="{StaticResource Muted}" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="&#xE711;" Click="Close_Click"
                        Style="{StaticResource WindowButton}" VerticalAlignment="Top" />
            </Grid>

            <!-- Filters -->
            <Grid Grid.Row="1" Margin="22,0,22,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="WeaponCombo" Grid.Column="0"
                          Style="{StaticResource DarkComboBox}"
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectionChanged="WeaponCombo_SelectionChanged" />

                <TextBox x:Name="SearchBox" Grid.Column="2"
                         Background="{StaticResource Panel}" Foreground="{StaticResource Text}"
                         BorderBrush="{StaticResource Border}" BorderThickness="1"
                         Padding="10,6" FontSize="12"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>

            <!-- Skin grid -->
            <Grid Grid.Row="2" Margin="22,0,22,20">
                <TextBlock x:Name="StatusText" Text="Loading skins..."
                           Foreground="{StaticResource Muted}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                <ScrollViewer x:Name="GridScroller" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <ItemsControl x:Name="SkinGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="148" Height="158" Margin="6" CornerRadius="8"
                                        Background="{StaticResource Card}"
                                        BorderBrush="{Binding RarityColor}" BorderThickness="1.4"
                                        Cursor="Hand" MouseLeftButtonUp="Tile_Click" Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#221C30" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Margin="9" VerticalAlignment="Center">
                                        <Image Source="{Binding ImageUrl}" Height="74" Stretch="Uniform" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                   FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                                   MaxHeight="46" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>

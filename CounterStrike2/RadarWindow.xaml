<Window x:Class="CounterStrike2.RadarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        Width="200" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Border Background="#E2080510" CornerRadius="10"
            BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <StackPanel Margin="12,10,12,12">

            <!-- Header — also the drag handle -->
            <Grid MouseLeftButtonDown="OnDrag" Cursor="SizeAll" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE81B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{StaticResource Accent}" Margin="0,0,6,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="RADAR" Foreground="{StaticResource Accent}"
                               FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="CountBadge" Grid.Column="1"
                           Foreground="{StaticResource Muted}"
                           FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Radar surface -->
            <Border Width="176" Height="176" CornerRadius="88"
                    Background="#120F1C" BorderBrush="{StaticResource Border}" BorderThickness="1"
                    ClipToBounds="True">
                <Canvas x:Name="RadarCanvas" Width="176" Height="176">
                    <!-- Range rings -->
                    <Ellipse Width="176" Height="176" Canvas.Left="0"  Canvas.Top="0"  Stroke="#241F33" StrokeThickness="1" />
                    <Ellipse Width="117" Height="117" Canvas.Left="29.5" Canvas.Top="29.5" Stroke="#241F33" StrokeThickness="1" />
                    <Ellipse Width="58"  Height="58"  Canvas.Left="59" Canvas.Top="59" Stroke="#241F33" StrokeThickness="1" />
                </Canvas>
            </Border>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyText" Text="No players"
                       Foreground="{StaticResource Muted}"
                       FontSize="11" FontFamily="Consolas"
                       HorizontalAlignment="Center" Margin="0,6,0,0" Visibility="Collapsed" />

        </StackPanel>
    </Border>
</Window>

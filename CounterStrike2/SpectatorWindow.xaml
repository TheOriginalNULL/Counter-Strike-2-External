<Window x:Class="CounterStrike2.SpectatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        Width="190" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Border Background="#E2080510" CornerRadius="10"
            BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <StackPanel Margin="12,10,12,12">

            <!-- Header — also the drag handle -->
            <Grid MouseLeftButtonDown="OnDrag" Cursor="SizeAll" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{StaticResource Accent}" Margin="0,0,6,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="SPECTATORS" Foreground="{StaticResource Accent}"
                               FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="CountBadge" Grid.Column="1"
                           Foreground="{StaticResource Muted}"
                           FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Center" />
            </Grid>

            <Rectangle Height="1" Fill="{StaticResource Border}" Margin="0,0,0,8" />

            <!-- Spectator names -->
            <ItemsControl x:Name="SpecList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource Accent}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource Text}"
                                       FontSize="12" FontFamily="Consolas" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyText" Text="None"
                       Foreground="{StaticResource Muted}"
                       FontSize="12" FontFamily="Consolas"
                       Margin="13,3,0,0" Visibility="Collapsed" />

        </StackPanel>
    </Border>
</Window>
